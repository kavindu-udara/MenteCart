# Copy to `.env` and fill values. This file should NOT be committed with secrets.
# Docker will use `.env` when running `docker-compose up`.

# App
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# MongoDB (connects to mongodb service in compose)
MONGO_URI=mongodb://root:password@mongodb:27017/mentecartdb?authSource=admin

# Redis
REDIS_URL=redis://redis:6379

# Any other env vars used by the app (JWT secrets, PAYHERE keys, etc.)
JWT_SECRET=your_jwt_secret

# bookings
MAX_DAILY_BOOKINGS=3
CANCELLATION_CUTOFF_HOURS=2

# payhere
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET= 
PAYHERE_SANDBOX_URL=
PAYHERE_PRODUCTION_URL=
PAYHERE_RETURN_URL=
PAYHERE_CANCEL_URL=
PAYHERE_NOTIFY_URL=
PAYHERE_IS_SANDBOX=true
PAYHERE_CURRENCY=USD # or LKR
